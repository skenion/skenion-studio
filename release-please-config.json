{
  "release-type": "node",
  "packages": {
    ".": {
      "package-name": "skenion-studio",
      "prerelease": true,
      "extra-files": [
        {
          "type": "toml",
          "path": "src-tauri/Cargo.toml",
          "jsonpath": "$.package.version"
        },
        {
          "type": "json",
          "path": "src-tauri/tauri.conf.json",
          "jsonpath": "$.version"
        },
        {
          "type": "json",
          "path": "packages/studio-web/package.json",
          "jsonpath": "$.version"
        },
        {
          "type": "json",
          "path": "packages/studio-desktop/package.json",
          "jsonpath": "$.version"
        }
      ]
    }
  }
}
