{
  "name": "skenion-studio",
  "version": "0.44.19",
  "description": "Mantine and React Flow studio shell for skenion graphs",
  "type": "module",
  "license": "Apache-2.0",
  "private": true,
  "scripts": {
    "build": "tsc -p tsconfig.json && vite build",
    "build-storybook": "storybook build",
    "ci": "pnpm run lint && pnpm run coverage && pnpm run build",
    "coverage": "vitest run --coverage",
    "dev": "vite --host localhost",
    "lint": "eslint .",
    "package-studio-desktop": "node scripts/package-studio-desktop.mjs",
    "prepare-studio-release-artifacts": "node scripts/prepare-studio-release-artifacts.mjs",
    "preview": "vite preview --host localhost",
    "stage-runtime-sidecar": "node scripts/stage-runtime-sidecar.mjs",
    "storybook": "storybook dev -p 6006 --host localhost",
    "tauri": "tauri",
    "tauri:build": "tauri build",
    "tauri:dev": "tauri dev",
    "test": "vitest run",
    "validate-release-workflow-policy": "node scripts/validate-release-workflow-policy.mjs",
    "validate-stage-runtime-sidecar": "node scripts/validate-stage-runtime-sidecar.mjs",
    "validate-studio-desktop-s3-existing-check": "bash scripts/validate-studio-desktop-s3-existing-check.sh",
    "validate-studio-desktop-s3-publisher": "bash scripts/validate-studio-desktop-asset-s3-publisher.sh",
    "visual-gate": "pnpm run build-storybook && pnpm run visual-gate:capture",
    "visual-gate:capture": "node scripts/capture-studio-visual-gate.mjs"
  },
  "dependencies": {
    "@mantine/core": "^9.3.1",
    "@mantine/hooks": "^9.3.1",
    "@skenion/contracts": "0.45.0",
    "@tauri-apps/api": "2.11.1",
    "@xyflow/react": "^12.11.0",
    "lucide-react": "^1.18.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@storybook/addon-a11y": "10.4.6",
    "@storybook/addon-docs": "10.4.6",
    "@storybook/react-vite": "^10.4.6",
    "@tauri-apps/cli": "2.11.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.9",
    "esbuild": "^0.28.1",
    "eslint": "^10.5.0",
    "globals": "^17.6.0",
    "happy-dom": "^20.10.6",
    "playwright": "^1.61.0",
    "storybook": "^10.4.6",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1",
    "vite": "^8.0.16",
    "vitest": "^4.1.9"
  },
  "packageManager": "pnpm@10.12.4"
}
