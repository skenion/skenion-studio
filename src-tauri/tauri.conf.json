{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "skenion studio",
  "version": "0.44.20",
  "identifier": "org.skenion.studio",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "security": {
      "csp": null
    },
    "windows": [
      {
        "label": "main",
        "title": "skenion studio",
        "width": 1440,
        "height": 960,
        "minWidth": 1024,
        "minHeight": 700
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ]
  }
}
